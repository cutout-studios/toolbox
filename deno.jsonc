{
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false
  },
  "license": "MIT",
  "lint": {
    "plugins": [
      "jsr:@ayk/lint-import-order"
    ]
  },
  "tasks": {
    "docs:lint": "deno doc --lint jsx/tokens/module.ts jsx/module.ts"
  },
  "workspace": [
    "jsx",
    "polyfill",
    "web",
    "elements",
    "tauri"
  ]
}
