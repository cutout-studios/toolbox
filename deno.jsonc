{
  "exports": {
    ".": "./pragma/module.ts",
    "./model": "./model/module.ts"
    // TODO: interpreters
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false
  },
  "imports": {
    "@std/testing": "jsr:@std/testing",
    "@cutout/jxs/model": "./model/module.ts"
  },
  "lint": {
    "plugins": [
      "jsr:@ayk/lint-import-order"
    ]
  },
  "name": "@cutout/jsx",
  "version": "0.0.0-alpha.0"
}
